# ============================================================================
# AutoHoneyX Real-Time Secret Detection Configuration
# GitGuardian-Style Monitoring & Incident Management
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://autohoneyx:secure_password@localhost:5432/autohoneyx_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autohoneyx_db
DB_USER=autohoneyx
DB_PASSWORD=secure_password
ENVIRONMENT=production

# ============================================================================
# Real-Time Scanning Configuration
# ============================================================================
SCAN_INTERVAL_SECONDS=300
AUTO_REMEDIATE=false
MONITORED_REPOS=/path/to/repos,/path/to/another/repo
PUBLIC_REPOS_TO_MONITOR=
LOG_FILE_PATH=./logs
LOG_LEVEL=INFO

# ============================================================================
# GitHub Integration (Real-Time Repo Scanning)
# ============================================================================
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_ORG=your-organization

# ============================================================================
# GitLab Integration (Real-Time Repo Scanning)
# ============================================================================
GITLAB_TOKEN=glpat-your_token_here
GITLAB_URL=https://gitlab.com

# ============================================================================
# Slack Integration (Real-Time Alerts)
# ============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#security-alerts

# ============================================================================
# Email Configuration (Critical Alerts)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@example.com
ALERT_EMAIL=security-team@example.com

# ============================================================================
# Custom Webhooks (for SIEM/Integration)
# ============================================================================
CUSTOM_WEBHOOKS=https://your-webhook.example.com/incidents

# ============================================================================
# Security Configuration
# ============================================================================
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ENCRYPTION_MASTER_KEY=your-encryption-key-32-bytes-long

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# TLS/SSL Configuration (for Production)
# ============================================================================
SSL_ENABLED=true
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# ============================================================================
# IP Reputation Configuration
# ============================================================================
ABUSEIPDB_API_KEY=your_abuseipdb_key

# ============================================================================
# Honeypot Configuration
# ============================================================================
SSH_HONEYPOT_PORT=2222
WEB_HONEYPOT_PORT=8080
DB_HONEYPOT_PORT=3307
AWS_REGION=us-east-1

# ============================================================================
# Monitoring & SIEM Integration
# ============================================================================
SPLUNK_HEC_URL=https://your-splunk.example.com:8088
SPLUNK_HEC_TOKEN=your_splunk_token
ELK_URL=https://your-elasticsearch.example.com:9200
PROMETHEUS_PORT=9090

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_GIT_HOOKS=true
ENABLE_PUBLIC_REPO_SCANNING=false
ENABLE_LOG_SCANNING=true
ENABLE_AUTO_REMEDIATION=false
ENABLE_SLACK_ALERTS=true
ENABLE_EMAIL_ALERTS=true

# Dashboard Configuration
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0

# CI/CD Configuration
GITHUB_REPO=yourusername/AutoHoneyX

# Enhanced Security Configuration
TOKEN_ENCRYPTION_KEY=your-32-byte-encryption-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
SESSION_SECRET_KEY=your-session-secret-key-here

# Authentication
ENABLE_AUTH=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=generated-hash-here

# Advanced Security Features
ADAPTIVE_HONEYPOTS=true
ANOMALY_DETECTION=true
THREAT_INTELLIGENCE=true

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BLOCK_DURATION_MINUTES=15

# Monitoring & Alerting
PROMETHEUS_METRICS=true
GRAFANA_DASHBOARD_URL=http://grafana:3000

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem